{
  "name": "TG-40-facebook-lead-sync",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 * * * *"
            }
          ]
        }
      },
      "id": "trigger-fb-lead-sync",
      "name": "Schedule - Hourly",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        0,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $vars.TG_SUPABASE_URL }}/rest/v1/facebook_lead_sync_state",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $vars.TG_SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $vars.TG_SUPABASE_SERVICE_KEY }}"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "select",
              "value": "last_synced_at,last_lead_id"
            },
            {
              "name": "limit",
              "value": "1"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "get-sync-state",
      "name": "Get Last Sync State",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        220,
        300
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const stateRaw = $input.first().json;\nconst states = Array.isArray(stateRaw) ? stateRaw : [stateRaw];\nconst state = states[0] || {};\nconst lastSyncedAt = state.last_synced_at || new Date(Date.now() - 60 * 60 * 1000).toISOString();\nconst sinceTimestamp = Math.floor(new Date(lastSyncedAt).getTime() / 1000);\nreturn [{ json: { lastSyncedAt, sinceTimestamp } }];"
      },
      "id": "parse-sync-state",
      "name": "Parse Sync State",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://graph.facebook.com/v19.0/me/leadgen_forms",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "access_token",
              "value": "={{ $vars.TG_FACEBOOK_ACCESS_TOKEN }}"
            },
            {
              "name": "fields",
              "value": "id,name,leads{id,created_time,field_data}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "get-fb-leads",
      "name": "Get Facebook Lead Ads",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        300
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const fbResult = $input.first().json;\nconst syncState = $('Parse Sync State').first().json;\nconst forms = fbResult?.data || [];\nconst sinceTimestamp = syncState.sinceTimestamp;\nconst newLeads = [];\nfor (const form of forms) {\n  const leads = form?.leads?.data || [];\n  for (const lead of leads) {\n    const leadTime = Math.floor(new Date(lead.created_time).getTime() / 1000);\n    if (leadTime > sinceTimestamp) {\n      const fields = {};\n      for (const f of (lead.field_data || [])) {\n        fields[f.name] = f.values?.[0] || '';\n      }\n      newLeads.push({\n        lead_id: lead.id,\n        created_time: lead.created_time,\n        form_id: form.id,\n        form_name: form.name,\n        name: fields.full_name || fields.name || '',\n        email: fields.email || '',\n        phone: fields.phone_number || fields.phone || '',\n        service: fields.service_type || fields.service || 'general'\n      });\n    }\n  }\n}\nreturn newLeads.length > 0 ? newLeads.map(l => ({ json: l })) : [{ json: { noNewLeads: true, count: 0 } }];"
      },
      "id": "filter-new-leads",
      "name": "Filter New Leads Since Last Sync",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-new-leads",
              "leftValue": "={{ !$json.noNewLeads }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "has-new-leads-check",
      "name": "Has New Leads?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1100,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.TG_SUPABASE_URL }}/rest/v1/leads",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $vars.TG_SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $vars.TG_SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=minimal"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"source\": \"facebook_lead_ad\",\n  \"external_id\": \"{{ $json.lead_id }}\",\n  \"name\": \"{{ $json.name }}\",\n  \"email\": \"{{ $json.email }}\",\n  \"phone\": \"{{ $json.phone }}\",\n  \"service_type\": \"{{ $json.service }}\",\n  \"form_name\": \"{{ $json.form_name }}\",\n  \"created_at\": \"{{ $json.created_time }}\",\n  \"synced_at\": \"{{ new Date().toISOString() }}\"\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "insert-lead",
      "name": "Insert Lead to Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1320,
        200
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.TG_SUPABASE_URL }}/rest/v1/facebook_lead_sync_state",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $vars.TG_SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $vars.TG_SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "resolution=merge-duplicates"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"id\": 1,\n  \"last_synced_at\": \"{{ new Date().toISOString() }}\"\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "update-sync-state",
      "name": "Update Sync State",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1540,
        300
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { skipped: true, reason: 'no_new_leads_since_last_sync' } }];"
      },
      "id": "no-new-leads",
      "name": "No New Leads",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1320,
        400
      ]
    }
  ],
  "connections": {
    "Schedule - Hourly": {
      "main": [
        [
          {
            "node": "Get Last Sync State",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Last Sync State": {
      "main": [
        [
          {
            "node": "Parse Sync State",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse Sync State": {
      "main": [
        [
          {
            "node": "Get Facebook Lead Ads",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Facebook Lead Ads": {
      "main": [
        [
          {
            "node": "Filter New Leads Since Last Sync",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Filter New Leads Since Last Sync": {
      "main": [
        [
          {
            "node": "Has New Leads?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Has New Leads?": {
      "main": [
        [
          {
            "node": "Insert Lead to Supabase",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "No New Leads",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Insert Lead to Supabase": {
      "main": [
        [
          {
            "node": "Update Sync State",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "availableInMCP": true
  }
}