{
  "name": "TG-132 AI Review Response Drafter",
  "nodes": [
    {
      "parameters": {},
      "id": "tg132-trigger",
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const review = $input.first().json;\nconst rating = Number(review.rating) || 0;\nconst authorName = review.author_name || 'Valued Customer';\nconst reviewText = review.review_text || '';\nconst isFiveStar = review.is_five_star === true || review.is_five_star === 'true';\n\nlet instructions = '';\n\nif (rating === 5) {\n  instructions = 'This is a 5-star review. Write a warm, grateful response. Mention specific details from the review to show you actually read it. Invite them back and thank them for choosing TotalGuard Yard Care.';\n} else if (rating === 4) {\n  instructions = 'This is a 4-star review. Be grateful and positive. If the reviewer mentioned any concerns, acknowledge them briefly and express your desire to earn 5 stars next time. Thank them for their trust in TotalGuard Yard Care.';\n} else {\n  instructions = `This is a ${rating}-star review. Be empathetic and professional. Apologize sincerely for their experience. Offer to make it right. Include the owner's direct phone number (608-535-6057) so they can reach you personally. Do NOT be defensive.`;\n}\n\nconst prompt = `You are Vance, the owner of TotalGuard Yard Care, a lawn care and landscaping company in Madison, WI. Write a Google review response.\n\n${instructions}\n\nTone: warm, professional, personal. NOT corporate or generic.\nSign off as: \"Vance, Owner of TotalGuard Yard Care\"\nMax 150 words.\n\nReviewer: ${authorName}\nRating: ${rating}/5\nReview: \"${reviewText}\"\n\nWrite the response now:`;\n\nreturn [{\n  json: {\n    ...review,\n    prompt: prompt\n  }\n}];"
      },
      "id": "tg132-build-prompt",
      "name": "Build AI Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        470,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "CLAUDE_API_KEY_PLACEHOLDER"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 300,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify($json.prompt) }}\n    }\n  ]\n}",
        "options": {}
      },
      "id": "tg132-ai",
      "name": "Call Claude Haiku",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        690,
        300
      ]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://lwtmvzhwekgdxkaisfra.supabase.co/rest/v1/google_reviews?review_id=eq.{{ $(\"Build AI Prompt\").item.json.review_id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "SUPABASE_ANON_KEY_PLACEHOLDER"
            },
            {
              "name": "Authorization",
              "value": "Bearer SUPABASE_ANON_KEY_PLACEHOLDER"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"response_draft\": {{ JSON.stringify($json.content[0].text) }}\n}",
        "options": {}
      },
      "id": "tg132-save",
      "name": "Save Draft",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        910,
        300
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const aiResponse = $input.first().json;\nconst review = $('Build AI Prompt').first().json;\nconst rating = Number(review.rating) || 0;\nconst authorName = review.author_name || 'Anonymous';\nconst reviewText = review.review_text || '';\nconst isFiveStar = review.is_five_star === true || review.is_five_star === 'true';\n\n// Extract AI draft from the PATCH response or fallback\nlet draftText = '';\nif (aiResponse && Array.isArray(aiResponse) && aiResponse[0] && aiResponse[0].response_draft) {\n  draftText = aiResponse[0].response_draft;\n} else {\n  const aiOutput = $('Call Claude Haiku').first().json;\n  draftText = (aiOutput.content && aiOutput.content[0] && aiOutput.content[0].text) || 'Error generating response';\n}\n\nconst stars = '\\u2B50'.repeat(rating);\nconst socialNote = isFiveStar ? '\\n\\n\\u2728 Queued for social media amplification' : '';\n\nconst message = `\\u{1F4E2} NEW GOOGLE REVIEW\\n\\n${stars} (${rating}/5)\\n\\u{1F464} ${authorName}\\n\\n\\u{1F4AC} Review:\\n\"${reviewText}\"\\n\\n\\u{1F916} AI Draft Response:\\n\"${draftText}\"${socialNote}\\n\\n\\u{1F449} Reply APPROVE to post as-is, or type your edited version.`;\n\nreturn [{\n  json: {\n    ...review,\n    draft_text: draftText,\n    telegram_message: message\n  }\n}];"
      },
      "id": "tg132-build-tg",
      "name": "Build Telegram Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1130,
        300
      ]
    },
    {
      "parameters": {
        "chatId": "OWNER_TELEGRAM_CHAT_ID",
        "text": "={{ $json.telegram_message }}",
        "additionalFields": {
          "parse_mode": "HTML"
        }
      },
      "id": "tg132-send-tg",
      "name": "Send to Telegram",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        1350,
        300
      ],
      "credentials": {
        "telegramApi": {
          "id": "V404qLIDXjmyzNeS",
          "name": "Telegram"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.is_five_star }}",
              "value2": true
            }
          ]
        }
      },
      "id": "tg132-social-flag",
      "name": "Check 5-Star",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1570,
        300
      ]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://lwtmvzhwekgdxkaisfra.supabase.co/rest/v1/google_reviews?review_id=eq.{{ $json.review_id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "SUPABASE_ANON_KEY_PLACEHOLDER"
            },
            {
              "name": "Authorization",
              "value": "Bearer SUPABASE_ANON_KEY_PLACEHOLDER"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"social_media_queued\": true\n}",
        "options": {}
      },
      "id": "tg132-social-update",
      "name": "Mark Queued for Social",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1790,
        220
      ],
      "continueOnFail": true
    }
  ],
  "connections": {
    "Execute Workflow Trigger": {
      "main": [
        [
          {
            "node": "Build AI Prompt",
