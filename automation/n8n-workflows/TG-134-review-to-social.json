          ],
          "combinator": "and"
        }
      },
      "id": "tg134-if-reviews",
      "name": "IF Reviews Found",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [690, 300]
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "tg134-split",
      "name": "Split In Batches",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [910, 300]
    },
    {
      "parameters": {
        "jsCode": "const review = $input.first().json;\n\n// Truncate review text to 200 chars\nconst fullText = review.review_text || '';\nconst truncated = fullText.length > 200 ? fullText.substring(0, 197) + '...' : fullText;\n\n// Build branded social post\nconst stars = '\\u2B50\\u2B50\\u2B50\\u2B50\\u2B50';\nconst authorName = review.author_name || 'A Happy Customer';\n\nconst postText = `${stars} 5-Star Review Spotlight\\n\\n\"${truncated}\"\\n\\n\\u2014 ${authorName}\\n\\nThank you for trusting TotalGuard Yard Care with your lawn! Ready for a yard transformation?\\n\\n\\uD83D\\uDC49 tgyardcare.com\\n\\n#TotalGuardYardCare #MadisonWI #LawnCare #5StarReview #CustomerLove #YardTransformation #LawnMaintenance #MadisonLawnCare`;\n\n// Calculate batch_week (current Monday)\nconst now = new Date();\nconst dayOfWeek = now.getDay();\nconst diffToMonday = dayOfWeek === 0 ? -6 : 1 - dayOfWeek;\nconst monday = new Date(now);\nmonday.setDate(now.getDate() + diffToMonday);\nmonday.setHours(0, 0, 0, 0);\nconst batchWeek = monday.toISOString().split('T')[0];\n\n// Calculate next Wednesday 10am CT (15:00 UTC)\nconst daysUntilWed = (3 - now.getDay() + 7) % 7;\nconst nextWed = new Date(now);\nif (daysUntilWed === 0 && now.getHours() >= 15) {\n  nextWed.setDate(now.getDate() + 7);\n} else {\n  nextWed.setDate(now.getDate() + (daysUntilWed === 0 ? 0 : daysUntilWed));\n}\nnextWed.setHours(15, 0, 0, 0);\nconst scheduledFor = nextWed.toISOString();\n\nconst socialPost = {\n  post_text: postText,\n  platforms: ['instagram', 'linkedin', 'pinterest'],\n  post_type: 'review_highlight',\n  pillar: 'review_spotlight',\n  day_of_week: 3,\n  status: 'scheduled',\n  source: 'review_highlight',\n  review_id: review.id,\n  batch_week: batchWeek,\n  scheduled_for: scheduledFor\n};\n\nreturn [{\n  json: {\n    social_post: socialPost,\n    review_id: review.id,\n    author_name: authorName\n  }\n}];"
      },
      "id": "tg134-generate-post",
      "name": "Generate Social Post",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1130, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://lwtmvzhwekgdxkaisfra.supabase.co/rest/v1/social_posts",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "sb_publishable_DeX21ldoDKl3NyJeFZzR1w_eWBUkx-v"
            },
            {
              "name": "Authorization",
              "value": "Bearer sb_publishable_DeX21ldoDKl3NyJeFZzR1w_eWBUkx-v"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.social_post) }}",
        "options": {}
      },
      "id": "tg134-insert-post",
      "name": "Insert to social_posts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1350, 300]
