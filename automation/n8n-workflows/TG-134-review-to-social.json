{
  "name": "TG-134 Review to Social Post",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 13 * * *"
            }
          ]
        }
      },
      "id": "tg134-trigger",
      "name": "Daily 8am CT",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://lwtmvzhwekgdxkaisfra.supabase.co/rest/v1/google_reviews?rating=eq.5&social_posted=eq.false&select=id,author_name,review_text,rating,created_at&order=created_at.desc&limit=3",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "sb_publishable_DeX21ldoDKl3NyJeFZzR1w_eWBUkx-v"
            },
            {
              "name": "Authorization",
              "value": "Bearer sb_publishable_DeX21ldoDKl3NyJeFZzR1w_eWBUkx-v"
            }
          ]
        },
        "options": {}
      },
      "id": "tg134-fetch-reviews",
      "name": "Fetch New 5-Star Reviews",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [200, 300],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "tg134-cond-1",
              "leftValue": "={{ Array.isArray($json) ? $json.length : ($input.all().length > 0 && !$input.first().json.code ? 1 : 0) }}",
              "rightValue": "0",
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "tg134-if-reviews",
      "name": "IF Reviews Found",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [400, 300]
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "tg134-split",
      "name": "Loop Over Reviews",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [600, 300]
    },
    {
      "parameters": {
        "jsCode": "const review = $input.first().json;\n\n// Truncate review text to 200 chars\nconst fullText = review.review_text || '';\nconst truncated = fullText.length > 200 ? fullText.substring(0, 197) + '...' : fullText;\n\nconst authorName = review.author_name || 'A Happy Customer';\n\n// Build branded social post per plan template\nconst postText = `\\u2B50 5-Star Review from ${authorName}!\\n\\n\"${truncated}\"\\n\\nThank you for trusting TotalGuard Yard Care with your lawn! Your satisfaction means the world to us.\\n\\nReady for YOUR lawn transformation?\\nFree quote: tgyardcare.com/quote\\n(608) 535-6057\\n\\n#TotalGuardYardCare #MadisonWI #LawnCare #5StarReview #HappyCustomer #MadisonLawnCare`;\n\n// Calculate batch_week (current Monday)\nconst now = new Date();\nconst dayOfWeek = now.getDay();\nconst diffToMonday = dayOfWeek === 0 ? -6 : 1 - dayOfWeek;\nconst monday = new Date(now);\nmonday.setDate(now.getDate() + diffToMonday);\nmonday.setHours(0, 0, 0, 0);\nconst batchWeek = monday.toISOString().split('T')[0];\n\n// Calculate next Wednesday 10am CT (15:00 UTC)\nconst daysUntilWed = (3 - now.getDay() + 7) % 7;\nconst nextWed = new Date(now);\nif (daysUntilWed === 0 && now.getHours() >= 15) {\n  nextWed.setDate(now.getDate() + 7);\n} else {\n  nextWed.setDate(now.getDate() + (daysUntilWed === 0 ? 0 : daysUntilWed));\n}\nnextWed.setHours(15, 0, 0, 0);\nconst scheduledFor = nextWed.toISOString();\n\nconst socialPost = {\n  post_text: postText,\n  platforms: ['instagram', 'linkedin', 'pinterest'],\n  post_type: 'review_highlight',\n  pillar: 'review_spotlight',\n  day_of_week: 3,\n  status: 'scheduled',\n  source: 'review_highlight',\n  review_id: review.id,\n  batch_week: batchWeek,\n  scheduled_for: scheduledFor\n};\n\nreturn [{\n  json: {\n    social_post: socialPost,\n    review_id: review.id,\n    author_name: authorName\n  }\n}];"
      },
      "id": "tg134-generate-post",
      "name": "Generate Social Post",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [800, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://lwtmvzhwekgdxkaisfra.supabase.co/rest/v1/social_posts",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "sb_publishable_DeX21ldoDKl3NyJeFZzR1w_eWBUkx-v"
            },
            {
              "name": "Authorization",
              "value": "Bearer sb_publishable_DeX21ldoDKl3NyJeFZzR1w_eWBUkx-v"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.social_post) }}",
        "options": {}
      },
      "id": "tg134-insert-post",
      "name": "Insert Social Post",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1000, 300]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://lwtmvzhwekgdxkaisfra.supabase.co/rest/v1/google_reviews?id=eq.{{ $('Generate Social Post').first().json.review_id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "sb_publishable_DeX21ldoDKl3NyJeFZzR1w_eWBUkx-v"
            },
            {
              "name": "Authorization",
              "value": "Bearer sb_publishable_DeX21ldoDKl3NyJeFZzR1w_eWBUkx-v"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{ \"social_posted\": true }",
        "options": {}
      },
      "id": "tg134-mark-posted",
      "name": "Mark Review as Posted",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1200, 300],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot{{TELEGRAM_BOT_TOKEN}}/sendMessage",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"chat_id\": \"OWNER_TELEGRAM_CHAT_ID\", \"text\": \"Review Social Post Created -- {{ $('Generate Social Post').first().json.author_name }}'s 5-star review queued for Wednesday posting.\", \"parse_mode\": \"Markdown\" }",
        "options": {}
      },
      "id": "tg134-telegram",
      "name": "Send Telegram Notification",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1400, 300]
    }
  ],
  "connections": {
