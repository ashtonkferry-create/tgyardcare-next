      "id": "tg134-fetch-reviews",
      "name": "Fetch New 5-Star Reviews",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [470, 300],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "tg134-cond-1",
              "leftValue": "={{ $json.length }}",
              "rightValue": "0",
              "operator": {
