              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{ \"social_media_posted\": true }",
        "options": {}
      },
      "id": "tg134-mark-posted",
      "name": "Mark Review as Posted",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
