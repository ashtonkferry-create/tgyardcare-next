{
  "name": "TG-78-voice-agent-sync",
  "nodes": [
    { "parameters": { "httpMethod": "POST", "path": "tg-vapi-webhook", "responseMode": "responseNode" }, "id": "webhook", "name": "VAPI Call Webhook", "type": "n8n-nodes-base.webhook", "typeVersion": 2, "position": [0, 300], "webhookId": "tg-vapi-webhook" },
    { "parameters": { "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst eventType = body.message?.type || body.type || 'unknown';\nconst call = body.message?.call || body.call || {};\nconst transcript = body.message?.artifact?.transcript || body.transcript || '';\nconst summary = body.message?.artifact?.summary || '';\nconst structuredData = body.message?.artifact?.structuredData || {};\n\nreturn [{ json: {\n  event_type: eventType,\n  call_id: call.id || '',\n  caller_phone: call.customer?.number || '',\n  duration: call.endedAt && call.startedAt ? Math.floor((new Date(call.endedAt) - new Date(call.startedAt)) / 1000) : 0,\n  ended_reason: call.endedReason || '',\n  transcript,\n  summary,\n  structured_data: structuredData,\n  received_at: new Date().toISOString()\n} }];" }, "id": "parse-vapi", "name": "Parse VAPI Event", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [220, 300] },
    { "parameters": { "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" }, "conditions": [{ "leftValue": "={{$json.event_type}}", "rightValue": "end-of-call-report", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" } }, "id": "is-call-end", "name": "Is End of Call?", "type": "n8n-nodes-base.if", "typeVersion": 2, "position": [440, 300] },
    { "parameters": { "method": "POST", "url": "=={{$vars.TG_SUPABASE_URL}}/rest/v1/voice_calls", "sendHeaders": true, "headerParameters": { "parameters": [{ "name": "apikey", "value": "={{$vars.TG_SUPABASE_ANON_KEY}}" }, { "name": "Authorization", "value": "=Bearer {{$vars.TG_SUPABASE_SERVICE_KEY}}" }, { "name": "Content-Type", "value": "application/json" }] }, "sendBody": true, "bodyParameters": { "parameters": [{ "name": "call_id", "value": "={{$json.call_id}}" }, { "name": "caller_phone", "value": "={{$json.caller_phone}}" }, { "name": "duration_seconds", "value": "={{$json.duration}}" }, { "name": "ended_reason", "value": "={{$json.ended_reason}}" }, { "name": "summary", "value": "={{$json.summary}}" }, { "name": "transcript", "value": "={{$json.transcript}}" }, { "name": "structured_data", "value": "={{JSON.stringify($json.structured_data)}}" }, { "name": "created_at", "value": "={{$json.received_at}}" }] } }, "id": "log-call", "name": "Log Call to DB", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [660, 200] },
    { "parameters": { "jsCode": "// Check if VAPI captured a lead from the call\nconst sd = $('Parse VAPI Event').first().json.structured_data || {};\nconst hasLead = sd.name || sd.email || sd.phone || sd.service;\nif (!hasLead) return [];\nreturn [{ json: { first_name: sd.name || '', email: sd.email || '', phone: sd.phone || $('Parse VAPI Event').first().json.caller_phone, service: sd.service || 'general inquiry', source: 'voice_agent', notes: sd.notes || $('Parse VAPI Event').first().json.summary, created_at: new Date().toISOString() } }];" }, "id": "extract-lead", "name": "Extract Lead from Call", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [660, 350] },
    { "parameters": { "method": "POST", "url": "=={{$vars.TG_SUPABASE_URL}}/rest/v1/leads", "sendHeaders": true, "headerParameters": { "parameters": [{ "name": "apikey", "value": "={{$vars.TG_SUPABASE_ANON_KEY}}" }, { "name": "Authorization", "value": "=Bearer {{$vars.TG_SUPABASE_SERVICE_KEY}}" }, { "name": "Content-Type", "value": "application/json" }] }, "sendBody": true, "bodyParameters": { "parameters": [{ "name": "first_name", "value": "={{$json.first_name}}" }, { "name": "email", "value": "={{$json.email}}" }, { "name": "phone", "value": "={{$json.phone}}" }, { "name": "service", "value": "={{$json.service}}" }, { "name": "source", "value": "voice_agent" }, { "name": "notes", "value": "={{$json.notes}}" }, { "name": "status", "value": "new" }, { "name": "created_at", "value": "={{$json.created_at}}" }] } }, "id": "save-lead", "name": "Save Lead from Call", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [880, 350] },
    { "parameters": { "respondWith": "json", "responseBody": "={\"received\": true}" }, "id": "ack", "name": "Acknowledge VAPI", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [440, 500] }
  ],
  "connections": { "VAPI Call Webhook": { "main": [[{ "node": "Parse VAPI Event", "type": "main", "index": 0 }]] }, "Parse VAPI Event": { "main": [[{ "node": "Is End of Call?", "type": "main", "index": 0 }]] }, "Is End of Call?": { "main": [[{ "node": "Log Call to DB", "type": "main", "index": 0 }], [{ "node": "Acknowledge VAPI", "type": "main", "index": 0 }]] }, "Log Call to DB": { "main": [[{ "node": "Extract Lead from Call", "type": "main", "index": 0 }]] }, "Extract Lead from Call": { "main": [[{ "node": "Save Lead from Call", "type": "main", "index": 0 }]] } },
  "settings": { "availableInMCP": true }
}
