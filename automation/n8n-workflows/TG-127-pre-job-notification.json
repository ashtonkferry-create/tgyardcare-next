        1130,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst name = input.customer_name || 'there';\nconst service = input.service ? ` for ${input.service}` : '';\nconst time = input.scheduled_time ? ` around ${input.scheduled_time}` : '';\n\nconst message = `Hi ${name}! This is TotalGuard Yard Care. Just a friendly reminder that we'll be at your property tomorrow${service}${time}. Please make sure gates are unlocked and pets are secured. Questions? Call 608-535-6057`;\n\nreturn [{\n  json: {\n    to_phone: input.customer_phone,\n    message_body: message,\n    workflow_name: 'TG-127-pre-job-notification',\n    message_type: 'pre_job_reminder'\n  }\n}];"
      },
      "id": "tg127-build-sms",
