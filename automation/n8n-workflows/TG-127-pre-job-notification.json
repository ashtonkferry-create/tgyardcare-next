{
  "id": "SsYWWFSHSOfnv7ex",
  "name": "TG-127 Pre-Job Notification",
  "nodes": [
    {
      "parameters": {},
      "id": "tg127-trigger",
      "name": "When Called by TG-05",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst scheduledDate = input.scheduled_date;\nconst now = new Date();\n\nif (!scheduledDate) {\n  return [{ json: { ...input, should_send: false, reason: 'no_scheduled_date' } }];\n}\n\nconst jobDate = new Date(scheduledDate + 'T09:00:00');\nconst dayBefore = new Date(jobDate);\ndayBefore.setDate(dayBefore.getDate() - 1);\ndayBefore.setHours(16, 0, 0, 0);\n\nif (dayBefore <= now) {\n  return [{ json: { ...input, should_send: true, send_now: true } }];\n}\n\nconst waitMinutes = Math.floor((dayBefore.getTime() - now.getTime()) / 60000);\nreturn [{ json: { ...input, should_send: true, send_now: false, wait_minutes: waitMinutes } }];"
      },
      "id": "tg127-calc-wait",
      "name": "Calculate Wait Until Day Before",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        470,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "tg127-cond-send",
              "leftValue": "={{ $json.should_send }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
