{
  "name": "TG-39-competitor-monitor",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 11 * * 3"
            }
          ]
        }
      },
      "id": "trigger-competitor-monitor",
      "name": "Schedule - Wednesday 6am CT",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        0,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $vars.TG_SUPABASE_URL }}/rest/v1/competitors",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $vars.TG_SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $vars.TG_SUPABASE_SERVICE_KEY }}"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "active",
              "value": "eq.true"
            },
            {
              "name": "select",
              "value": "id,name,google_place_id,last_known_rating,last_known_review_count"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "get-competitors",
      "name": "Get Competitor List",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        220,
        300
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const competitors = Array.isArray($input.first().json) ? $input.first().json : [];\nreturn competitors.map(c => ({ json: c }));"
      },
      "id": "split-competitors",
      "name": "Split Competitors",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://maps.googleapis.com/maps/api/place/details/json",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "place_id",
              "value": "={{ $json.google_place_id }}"
            },
            {
              "name": "fields",
              "value": "rating,user_ratings_total,name"
            },
            {
              "name": "key",
              "value": "={{ $vars.TG_GOOGLE_PLACES_API_KEY || '' }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "get-google-rating",
      "name": "Get Google Places Rating",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        300
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const placeResult = $input.first().json;\nconst competitor = $('Split Competitors').first().json;\nconst result = placeResult?.result || {};\nconst newRating = result.rating || competitor.last_known_rating || 0;\nconst newReviewCount = result.user_ratings_total || competitor.last_known_review_count || 0;\nconst ratingDropped = newRating < (competitor.last_known_rating || 5);\nconst TG_RATING = 5.0;\nconst competitorBelowTG = newRating < TG_RATING;\nreturn [{\n  json: {\n    ...competitor,\n    newRating,\n    newReviewCount,\n    ratingDropped,\n    competitorBelowTG,\n    shouldAlert: ratingDropped || competitorBelowTG,\n    checkedAt: new Date().toISOString()\n  }\n}];"
      },
      "id": "parse-competitor-rating",
      "name": "Parse Competitor Rating",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.TG_SUPABASE_URL }}/rest/v1/competitor_snapshots",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $vars.TG_SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $vars.TG_SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=minimal"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"competitor_id\": \"{{ $json.id }}\",\n  \"competitor_name\": \"{{ $json.name }}\",\n  \"rating\": {{ $json.newRating }},\n  \"review_count\": {{ $json.newReviewCount }},\n  \"rating_dropped\": {{ $json.ratingDropped }},\n  \"checked_at\": \"{{ $json.checkedAt }}\"\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "insert-competitor-snapshot",
      "name": "Insert Competitor Snapshot",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1100,
        300
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "should-alert",
              "leftValue": "={{ $json.shouldAlert }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "should-alert-check",
      "name": "Should Alert Owner?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1320,
        300
      ]
    },
    {
      "id": "sms-owner-competitor",
      "name": "SMS Owner - Competitor Alert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1540,
        200
      ],
      "continueOnFail": true,
      "parameters": {
        "method": "POST",
        "url": "https://api.brevo.com/v3/transactionalSMS/sms",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "api-key",
              "value": "={{$vars.TG_BREVO_API_KEY}}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {
              "name": "sender",
              "value": "TotalGuard"
            },
            {
              "name": "recipient",
              "value": "={{ $vars.TG_OWNER_PHONE }}"
            },
            {
              "name": "content"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { skipped: true, reason: 'no_alert_needed', competitor: $json.name, rating: $json.newRating } }];"
      },
      "id": "no-alert-needed",
      "name": "No Alert Needed",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1540,
        400
      ]
    }
  ],
  "connections": {
    "Schedule - Wednesday 6am CT": {
      "main": [
        [
          {
            "node": "Get Competitor List",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Competitor List": {
      "main": [
        [
          {
            "node": "Split Competitors",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Split Competitors": {
      "main": [
        [
          {
            "node": "Get Google Places Rating",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Google Places Rating": {
      "main": [
        [
          {
            "node": "Parse Competitor Rating",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse Competitor Rating": {
      "main": [
        [
          {
            "node": "Insert Competitor Snapshot",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Insert Competitor Snapshot": {
      "main": [
        [
          {
            "node": "Should Alert Owner?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Should Alert Owner?": {
      "main": [
        [
          {
            "node": "SMS Owner - Competitor Alert",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "No Alert Needed",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "availableInMCP": true
  }
}