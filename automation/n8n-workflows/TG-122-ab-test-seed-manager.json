      ]
    },
    "Update Variant B": {
      "main": [
        [{ "node": "Return Update Result", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
    { "name": "phase-4-intelligence" },
    { "name": "ab-testing" },
    { "name": "sub-workflow" }
  ]
}