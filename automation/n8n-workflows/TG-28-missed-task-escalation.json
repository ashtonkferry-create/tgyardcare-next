{
  "name": "TG-28-missed-task-escalation",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 14 * * *"
            }
          ]
        }
      },
      "id": "schedule",
      "name": "Daily 9am CT",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        0,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=={{$vars.TG_SUPABASE_URL}}/rest/v1/field_marketing_tasks?status=eq.pending&created_at=lt.{{ new Date().toISOString().split('T')[0] }}&select=id,job_address,created_at",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$vars.TG_SUPABASE_ANON_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{$vars.TG_SUPABASE_SERVICE_KEY}}"
            }
          ]
        }
      },
      "id": "fetch-missed",
      "name": "Fetch Yesterday Missed Tasks",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        220,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const tasks = $input.all().map(i => i.json);\nif (tasks.length === 0) return [{ json: { skip: true } }];\nconst list = tasks.map(t => t.job_address).join(', ');\nreturn [{ json: { tasks, count: tasks.length, message: `TG MISSED TASKS: ${tasks.length} field task(s) not completed yesterday.\\nAddresses: ${list}\\nFollow up today! - TG System` } }];"
      },
      "id": "format-escalation",
      "name": "Format Escalation",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        300
      ]
    },
    {
      "id": "sms-owner",
      "name": "Alert Owner",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        300
      ],
      "continueOnFail": false,
      "parameters": {
        "method": "POST",
        "url": "https://api.brevo.com/v3/transactionalSMS/sms",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "api-key",
              "value": "={{$vars.TG_BREVO_API_KEY}}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {
              "name": "sender",
              "value": "TotalGuard"
            },
            {
              "name": "recipient",
              "value": "={{$vars.TG_OWNER_PHONE}}"
            },
            {
              "name": "content",
              "value": "={{$json.message}}"
            }
          ]
        },
        "options": {}
      }
    }
  ],
  "connections": {
    "Daily 9am CT": {
      "main": [
        [
          {
            "node": "Fetch Yesterday Missed Tasks",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Yesterday Missed Tasks": {
      "main": [
        [
          {
            "node": "Format Escalation",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Format Escalation": {
      "main": [
        [
          {
            "node": "Alert Owner",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "availableInMCP": true
  }
}