{
  "name": "TG-140 Review Alert",
  "nodes": [
    {
      "parameters": {},
      "id": "tg140-trigger",
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [0, 300]
    },
    {
      "parameters": {
        "jsCode": "const { rating } = $json;\n\nlet severity;\nif (rating <= 3) {\n  severity = 'CRITICAL';\n} else if (rating === 4) {\n  severity = 'WARNING';\n} else {\n  severity = 'INFO';\n}\n\nreturn [{ json: { ...$json, severity } }];"
      },
      "id": "tg140-severity",
      "name": "Determine Severity",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "jsCode": "const { author_name, rating, review_text, review_id, severity } = $json;\n\nconst stars = '⭐'.repeat(rating) + '☆'.repeat(5 - rating);\n\nlet header = '';\nif (severity === 'CRITICAL') {\n  header = '🚨 RESPOND IMMEDIATELY\\n\\n';\n}\n\nconst message = [\n  `${header}📝 NEW REVIEW (${severity})`,\n  ``,\n  `${stars} (${rating}/5)`,\n  `Author: ${author_name || 'Anonymous'}`,\n  ``,\n  `\"${review_text || 'No text provided'}\"`,\n  ``,\n  `Review ID: ${review_id || 'N/A'}`\n].join('\\n');\n\nreturn [{ json: {\n  alert_message: message,\n  severity,\n  author_name: author_name || 'Anonymous',\n  rating,\n  review_id\n} }];"
      },
      "id": "tg140-build-alert",
      "name": "Build Alert",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "critical-check",
              "leftValue": "={{ $json.severity }}",
              "rightValue": "CRITICAL",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "tg140-route",
      "name": "Route by Severity",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [720, 300]
    },
    {
      "parameters": {
        "workflowId": "GHL1BUPFZL8Ic6Bc",
        "options": {},
        "workflowInputs": {
          "value": {
            "alert_type": "negative_review",
            "alert_title": "=Negative Review from {{ $json.author_name }} ({{ $json.rating }}/5)",
            "alert_body": "={{ $json.alert_message }}",
            "severity": "critical",
            "source_workflow": "TG-140",
            "metadata": "={{ JSON.stringify({ review_id: $json.review_id, rating: $json.rating }) }}"
          }
        }
      },
      "id": "tg140-alert-router",
      "name": "Call TG-113 Alert Router",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.1,
      "position": [960, 200]
    },
    {
      "parameters": {
        "chatId": "OWNER_TELEGRAM_CHAT_ID",
        "text": "={{ $('Build Alert').first().json.alert_message }}",
        "additionalFields": {
          "parse_mode": "HTML"
        }
      },
      "id": "tg140-telegram-critical",
      "name": "Send Telegram (Critical)",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1200, 200],
      "credentials": {
        "telegramApi": {
          "id": "V404qLIDXjmyzNeS",
          "name": "Telegram"
        }
      }
    },
    {
      "parameters": {
        "chatId": "OWNER_TELEGRAM_CHAT_ID",
        "text": "={{ $('Build Alert').first().json.alert_message }}",
        "additionalFields": {
          "parse_mode": "HTML"
        }
      },
      "id": "tg140-telegram-other",
      "name": "Send Telegram",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [960, 420],
      "credentials": {
        "telegramApi": {
          "id": "V404qLIDXjmyzNeS",
          "name": "Telegram"
        }
      }
    }
  ],
  "connections": {
    "Execute Workflow Trigger": {
      "main": [
        [{ "node": "Determine Severity", "type": "main", "index": 0 }]
      ]
    },
    "Determine Severity": {
      "main": [
        [{ "node": "Build Alert", "type": "main", "index": 0 }]
      ]
    },
    "Build Alert": {
      "main": [
        [{ "node": "Route by Severity", "type": "main", "index": 0 }]
      ]
    },
    "Route by Severity": {
      "main": [
        [{ "node": "Call TG-113 Alert Router", "type": "main", "index": 0 }],
        [{ "node": "Send Telegram", "type": "main", "index": 0 }]
      ]
    },
    "Call TG-113 Alert Router": {
      "main": [
        [{ "node": "Send Telegram (Critical)", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "callerPolicy": "workflowsFromSameOwner",
    "executionOrder": "v1"
  },
  "active": false
}