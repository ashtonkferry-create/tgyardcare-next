{
  "name": "TG-32-seasonal-transition",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 14 1 * *"
            }
          ]
        }
      },
      "id": "schedule",
      "name": "1st of Month 9am CT",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 300]
    },
    {
      "parameters": {
        "jsCode": "const month = new Date().getMonth() + 1;\nlet campaign = null;\nlet season = null;\n\nswitch (month) {\n  case 3:\n    campaign = 'TG-14';\n    season = 'Spring';\n    break;\n  case 9:\n    campaign = 'TG-15';\n    season = 'Fall';\n    break;\n  case 11:\n    campaign = 'TG-16';\n    season = 'Snow';\n    break;\n  default:\n    campaign = null;\n    season = 'none';\n    break;\n}\n\nreturn [{ json: { month, season, campaign } }];"
      },
      "id": "determine-season",
      "name": "Determine Season",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "campaign-not-null",
              "leftValue": "={{ $json.campaign }}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "isNotEmpty" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-campaign-due",
      "name": "IF Campaign Due",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "chatId": "{{ $env.TG_TELEGRAM_CHAT_ID }}",
        "text": "=\ud83d\udcc5 **Seasonal Transition Router**\n\nMonth: {{ $json.month }}\nSeason: {{ $json.season }}\nCampaign: {{ $json.campaign }}\n\nLaunching {{ $json.campaign }} campaign now.",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "id": "telegram-notify",
      "name": "Telegram Notify",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [660, 200],
      "credentials": {
        "telegramApi": { "id": "V404qLIDXjmyzNeS", "name": "Telegram" }
      }
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.campaign }}",
                    "rightValue": "TG-14",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "TG-14"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.campaign }}",
                    "rightValue": "TG-15",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "TG-15"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.campaign }}",
                    "rightValue": "TG-16",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "TG-16"
            }
          ]
        }
      },
      "id": "switch-campaign",
      "name": "Switch Campaign",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [880, 200]
    },
    {
      "parameters": {
        "workflowId": "nAYg8H9q6kqhtGbT",
        "options": {}
      },
      "id": "execute-tg14",
      "name": "Execute TG-14",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [1100, 100]
    },
    {
      "parameters": {
        "workflowId": "RRym6KRyPue6GABC",
        "options": {}
      },
      "id": "execute-tg15",
      "name": "Execute TG-15",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [1100, 300]
    },
    {
      "parameters": {
        "workflowId": "EUZtUKUAHDMUfgmi",
        "options": {}
      },
      "id": "execute-tg16",
      "name": "Execute TG-16",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [1100, 500]
    }
  ],
  "connections": {
    "1st of Month 9am CT": {
      "main": [[{ "node": "Determine Season", "type": "main", "index": 0 }]]
    },
    "Determine Season": {
      "main": [[{ "node": "IF Campaign Due", "type": "main", "index": 0 }]]
    },
    "IF Campaign Due": {
      "main": [
        [{ "node": "Telegram Notify", "type": "main", "index": 0 }],
        []
      ]
    },
    "Telegram Notify": {
      "main": [[{ "node": "Switch Campaign", "type": "main", "index": 0 }]]
    },
    "Switch Campaign": {
      "main": [
        [{ "node": "Execute TG-14", "type": "main", "index": 0 }],
        [{ "node": "Execute TG-15", "type": "main", "index": 0 }],
        [{ "node": "Execute TG-16", "type": "main", "index": 0 }]
      ]
    }
  },
  "active": false,
  "settings": { "executionOrder": "v1", "callerPolicy": "workflowsFromSameOwner" },
  "versionId": "1",
  "meta": {
    "instanceId": "tgyardcare"
  },
  "tags": [
    { "name": "seasonal" },
    { "name": "router" },
    { "name": "phase-15" }
  ]
}
