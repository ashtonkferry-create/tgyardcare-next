      "typeVersion": 4.2,
      "position": [880, -100],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const leads = $input.first().json;\nconst parsed = $('Parse Quo Webhook').first().json;\nconst isArray = Array.isArray(leads);\nconst hasLead = isArray ? leads.length > 0 : !!(leads && leads.id);\nconst lead = isArray ? leads[0] : leads;\n\nreturn [{\n  json: {\n    has_lead: hasLead,\n    lead_id: hasLead ? lead.id : null,\n    customer_name: hasLead ? (lead.first_name + ' ' + (lead.last_name || '')).trim() : (parsed.caller_name || 'Unknown Caller'),\n    from_phone: parsed.from_phone,\n    call_id: parsed.call_id\n  }\n}];"
      },
