        "jsonBody": "={\n  \"call_sid\": \"{{ $json.call_id }}\",\n  \"from_phone\": \"{{ $json.from_phone }}\",\n  \"to_phone\": \"{{ $json.to_phone }}\",\n  \"caller_name\": \"{{ $json.caller_name }}\",\n  \"call_status\": \"missed\"\n}"
      },
