    {
      "parameters": {
        "jsCode": "// Check if customer has opted out\n// fullResponse:true means input is always {statusCode,headers,body}\nconst fullResp = $input.first().json;\nconst consentResult = fullResp.body !== undefined ? fullResp.body : fullResp;\nconst routeData = $('Prepare Route Data').first().json;\n\nlet isOptedOut = false;\nif (Array.isArray(consentResult)) {\n  isOptedOut = consentResult.length > 0;\n} else if (consentResult && consentResult.id) {\n  isOptedOut = true;\n}\n\nreturn [{\n  json: {\n    ...routeData,\n    is_opted_out: isOptedOut\n  }\n}];"
      },
