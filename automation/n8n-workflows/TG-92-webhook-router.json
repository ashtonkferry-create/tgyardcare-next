      "parameters": {
        "jsCode": "// Prepare routing data, carrying forward source info and webhook_event_id\nconst detectData = $('Evaluate Duplicate').first().json;\nconst logResponse = $input.first().json;\n\n// logResponse is the webhook_events row returned by Prefer: return=representation\nconst webhookEventId = Array.isArray(logResponse) ? (logResponse[0] || {}).id : logResponse.id;\n\nreturn [{\n  json: {\n    source: detectData.source,\n    event_type: detectData.event_type,\n    smsIntent: detectData.smsIntent,\n    raw_payload: detectData.raw_payload,\n    from_phone: detectData.from_phone,\n    message_body: detectData.message_body,\n    idempotency_key: detectData.idempotency_key,\n    webhook_event_id: webhookEventId || null\n  }\n}];"
      },
