      "id": "tg92-webhook",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 300],
      "webhookId": "tg92-router"
    },
    {
      "parameters": {
        "jsCode": "// Detect the source of the inbound webhook and classify SMS intent\nconst body = $input.first().json.body || $input.first().json;\n\nlet source = 'unknown';\nlet event_type = 'unknown';\n\nif (body.From && body.Body !== undefined && body.MessageSid) {\n  source = 'twilio_sms';\n  event_type = 'inbound_sms';\n} else if (body.first_name || body.email) {\n  source = 'web_form';\n  event_type = 'lead_capture';\n}\n\nlet smsIntent = null;\nif (source === 'twilio_sms') {\n  const from = (body.From || '').replace(/[^0-9+]/g, '');\n  const text = (body.Body || '').trim().toLowerCase();\n  const isOwner = from === 'OWNER_PHONE_PLACEHOLDER';\n\n  if (isOwner && ['1', 'yes', 'confirm'].includes(text)) smsIntent = 'dispatch_confirm';\n  else if (isOwner && ['2', 'no', 'flag'].includes(text)) smsIntent = 'dispatch_flag';\n  else if (['stop', 'unsubscribe', 'quit', 'cancel', 'end'].includes(text)) smsIntent = 'opt_out';\n  else if (['start', 'subscribe'].includes(text)) smsIntent = 'opt_in';\n  else if (text === 'help') smsIntent = 'help';\n  else smsIntent = 'general';\n}\n\nreturn [{\n  json: {\n    source,\n    event_type,\n    smsIntent,\n    idempotency_key: body.MessageSid || null,\n    from_phone: body.From || null,\n    message_body: body.Body || null,\n    raw_payload: body\n  }\n}];"
      },
      "id": "tg92-detect-source",
      "name": "Detect Source",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://lwtmvzhwekgdxkaisfra.supabase.co/rest/v1/webhook_events?idempotency_key=eq.{{ $json.idempotency_key }}&select=id&limit=1",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "SUPABASE_SECRET_KEY" },
            { "name": "Authorization", "value": "Bearer SUPABASE_SECRET_KEY" }
          ]
        },
        "options": {
          "timeout": 3000,
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        }
      },
      "id": "tg92-check-idempotency",
      "name": "Check Idempotency",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 300]
    },
    {
      "parameters": {
        "jsCode": "// Check if the idempotency lookup returned any existing records\n// fullResponse: true means input is always {statusCode, headers, body} (never 0 items)\nconst fullResp = $input.first().json;\nconst body = fullResp.body || fullResp;\nconst detectData = $('Detect Source').first().json;\n\nlet isDuplicate = false;\nif (Array.isArray(body)) {\n  isDuplicate = body.length > 0;\n} else if (body && typeof body === 'object') {\n  isDuplicate = !!body.id;\n}\n\n// Skip idempotency check if key is null (non-SMS source)\nif (!detectData.idempotency_key) {\n  isDuplicate = false;\n}\n\nreturn [{\n  json: {\n    ...detectData,\n    is_duplicate: isDuplicate\n  }\n}];"
      },
      "id": "tg92-eval-duplicate",
      "name": "Evaluate Duplicate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 300]
