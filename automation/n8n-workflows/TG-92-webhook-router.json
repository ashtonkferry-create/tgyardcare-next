      "id": "tg92-rate-limit-check",
      "name": "Rate Limit Check",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2880, 800]
    },
    {
      "parameters": {
        "jsCode": "// Parse rate limit from Content-Range header\nconst response = $input.first().json;\nconst contentRange = response.headers?.['content-range'] || '';\nconst routeData = $('Evaluate Consent').first().json;\n\n// Content-Range format: 0-0/N where N is total count\nlet count = 0;\nconst match = contentRange.match(/\\/(\\d+)/);\nif (match) count = parseInt(match[1], 10);\n\nconst MAX_DAILY_SMS = 3;\nconst isRateLimited = count >= MAX_DAILY_SMS;\n\nreturn [{\n  json: {\n    ...routeData,\n    daily_sms_count: count,\n    is_rate_limited: isRateLimited\n  }\n}];"
      },
