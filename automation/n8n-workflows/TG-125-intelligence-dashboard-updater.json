      "parameters": {
        "jsCode": "// Calculate date boundaries for 7d and 30d windows\nconst now = new Date();\nconst today = now.toISOString().split('T')[0];\n\nconst sevenDaysAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);\nconst sevenDaysAgoStr = sevenDaysAgo.toISOString().split('T')[0] + 'T00:00:00Z';\n\nconst thirtyDaysAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);\nconst thirtyDaysAgoStr = thirtyDaysAgo.toISOString().split('T')[0] + 'T00:00:00Z';\n\nreturn [{ json: {\n  today,\n  sevenDaysAgoStr,\n  thirtyDaysAgoStr,\n  nowIso: now.toISOString()\n} }];"
      },
      "id": "calc-dates",
      "name": "Calculate Date Ranges",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 300]
    },
