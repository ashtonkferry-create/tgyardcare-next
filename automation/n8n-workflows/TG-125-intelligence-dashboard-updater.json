        "jsonBody": "={{ JSON.stringify({\n  metric_name: $json.metric_name,\n  metric_type: $json.metric_type,\n  value: $json.value,\n  metadata: $json.metadata,\n  recorded_at: $json.recorded_at\n}) }}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        }
      },
