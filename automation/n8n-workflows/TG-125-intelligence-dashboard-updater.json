      "id": "count-alerts",
      "name": "Count Unresolved Alerts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 680]
    },
    {
      "parameters": {
        "jsCode": "// Compute rolling averages and summary metrics for dashboard\nconst metrics7d = $('Fetch 7-Day Metrics').first().json;\nconst metrics30d = $('Fetch 30-Day Metrics').first().json;\nconst abTestsRaw = $('Count Active A/B Tests').first().json;\nconst alertsRaw = $('Count Unresolved Alerts').first().json;\n\nconst data7d = metrics7d.body || [];\nconst data30d = metrics30d.body || [];\n\n// Parse content-range for counts\nfunction parseCount(raw) {\n  const cr = raw.headers?.['content-range'] || '';\n  const match = cr.match(/\\/(\\d+)/);\n  return match ? parseInt(match[1]) : 0;\n}\n\nconst activeAbTests = parseCount(abTestsRaw);\nconst unresolvedAlerts = parseCount(alertsRaw);\n\n// Helper: average of numeric values by metric_type\nfunction avgByType(data, metricType) {\n  const filtered = data.filter(m => m.metric_type === metricType);\n  if (filtered.length === 0) return 0;\n  const sum = filtered.reduce((s, m) => s + (parseFloat(m.value) || 0), 0);\n  return Math.round((sum / filtered.length) * 100) / 100;\n}\n\n// Calculate rolling averages for key metric types\nconst metricTypes = ['kpi_snapshot', 'revenue_daily', 'lead_quality', 'workflow_performance', 'anomaly_score'];\n\nconst summaries = [];\n\nfor (const mt of metricTypes) {\n  summaries.push({\n    metric_name: `summary_7d_avg_${mt}`,\n    metric_type: 'dashboard_summary',\n    value: avgByType(data7d, mt),\n    metadata: JSON.stringify({ window: '7d', source_type: mt, data_points: data7d.filter(m => m.metric_type === mt).length })\n  });\n  summaries.push({\n    metric_name: `summary_30d_avg_${mt}`,\n    metric_type: 'dashboard_summary',\n    value: avgByType(data30d, mt),\n    metadata: JSON.stringify({ window: '30d', source_type: mt, data_points: data30d.filter(m => m.metric_type === mt).length })\n  });\n}\n\n// Add count metrics\nsummaries.push({\n  metric_name: 'summary_active_ab_tests',\n  metric_type: 'dashboard_summary',\n  value: activeAbTests,\n  metadata: JSON.stringify({ description: 'Currently active A/B tests' })\n});\n\nsummaries.push({\n  metric_name: 'summary_unresolved_alerts',\n  metric_type: 'dashboard_summary',\n  value: unresolvedAlerts,\n  metadata: JSON.stringify({ description: 'Unresolved intelligence alerts' })\n});\n\nsummaries.push({\n  metric_name: 'summary_total_7d_metrics',\n  metric_type: 'dashboard_summary',\n  value: data7d.length,\n  metadata: JSON.stringify({ description: 'Total metric data points in 7d window' })\n});\n\nsummaries.push({\n  metric_name: 'summary_total_30d_metrics',\n  metric_type: 'dashboard_summary',\n  value: data30d.length,\n  metadata: JSON.stringify({ description: 'Total metric data points in 30d window' })\n});\n\nreturn summaries.map(s => ({ json: {\n  ...s,\n  recorded_at: new Date().toISOString()\n} }));"
      },
      "id": "compute-summaries",
      "name": "Compute Dashboard Summaries",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [760, 400]
    },
