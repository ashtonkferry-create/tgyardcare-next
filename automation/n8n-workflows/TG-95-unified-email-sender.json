{
  "name": "TG-95-unified-email-sender",
  "nodes": [
    {
      "parameters": {},
      "id": "trigger",
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [
        0,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst to_email = (input.to_email || '').trim();\nconst subject = (input.subject || '').trim();\nconst html_body = (input.html_body || '').trim();\nconst workflow_name = input.workflow_name || 'unknown';\nconst email_type = input.email_type || 'transactional';\n\nif (!to_email || !subject || !html_body) {\n  return [{ json: { sent: false, reason: 'missing_params', to_email, workflow_name } }];\n}\n\nreturn [{ json: { to_email, subject, html_body, workflow_name, email_type, valid: true } }];"
      },
      "id": "validate-input",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "valid-check",
              "leftValue": "={{ $json.valid }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals",
                "name": "filter.operator.equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-valid",
      "name": "IF Valid Input",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        440,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.resend.com/emails",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer re_gGiHwMZh_N6HPDCkepZeBfWefXdyVL5Gj"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ from: 'TotalGuard <hello@tgyardcare.com>', to: [$json.to_email], subject: $json.subject, html: $json.html_body }) }}"
      },
      "id": "send-email",
      "name": "Send Email via Resend",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        200
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const result = $input.first().json;\nconst prev = $('Validate Input').first().json;\n\n// Resend returns { id: '...' } on success, or error fields on failure\nif (result.id && !result.statusCode && !result.error) {\n  return [{ json: { sent: true, email_id: result.id, to_email: prev.to_email, workflow_name: prev.workflow_name, _needsRetry: false } }];\n}\n\n// Error — mark for retry\nreturn [{ json: { sent: false, error: result.message || result.error || 'unknown_error', to_email: prev.to_email, workflow_name: prev.workflow_name, _needsRetry: true, subject: prev.subject, html_body: prev.html_body } }];"
      },
      "id": "check-result",
      "name": "Check Send Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        200
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "retry-check",
              "leftValue": "={{ $json._needsRetry }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals",
                "name": "filter.operator.equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-needs-retry",
      "name": "IF Needs Retry",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1100,
        200
      ]
    },
    {
      "parameters": {
        "amount": 10,
        "unit": "seconds"
      },
      "id": "wait-retry",
      "name": "Wait 10s",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        1320,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.resend.com/emails",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer re_gGiHwMZh_N6HPDCkepZeBfWefXdyVL5Gj"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ from: 'TotalGuard <hello@tgyardcare.com>', to: [$json.to_email], subject: $json.subject, html: $json.html_body }) }}"
      },
      "id": "retry-email",
      "name": "Retry Email via Resend",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1540,
        300
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const result = $input.first().json;\nconst prev = $('Validate Input').first().json;\n\nif (result.id && !result.statusCode && !result.error) {\n  return [{ json: { sent: true, email_id: result.id, to_email: prev.to_email, workflow_name: prev.workflow_name } }];\n}\n\nreturn [{ json: { sent: false, error: result.message || result.error || 'retry_failed', to_email: prev.to_email, workflow_name: prev.workflow_name } }];"
      },
      "id": "check-retry-result",
      "name": "Check Retry Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1760,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Passthrough for invalid input\nreturn $input.all();"
      },
      "id": "return-invalid",
      "name": "Return Invalid",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        400
      ]
    }
  ],
  "connections": {
