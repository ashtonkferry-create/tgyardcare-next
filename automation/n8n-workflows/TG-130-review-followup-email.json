    "Build Email Payload": {
      "main": [
        [
          {
            "node": "Send via TG-95",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send via TG-95": {
      "main": [
        [
          {
            "node": "Update Request Record",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "active": false
}