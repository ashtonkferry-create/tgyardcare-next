              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ (() => { const post = $('IF Post Found').first().json; const published = $('Check Result').first().json.success === true; const postPreview = (post.post_text || '').substring(0, 50); if (published) { return JSON.stringify({ chat_id: $env.{{ $env.TG_TELEGRAM_CHAT_ID }} || '{{ $env.TG_TELEGRAM_CHAT_ID }}', text: '\\u2705 Published: \"' + postPreview + '...\"', parse_mode: 'HTML' }); } else { return JSON.stringify({ chat_id: $env.{{ $env.TG_TELEGRAM_CHAT_ID }} || '{{ $env.TG_TELEGRAM_CHAT_ID }}', text: '\\u274c FAILED to publish (ID: ' + post.id + ')', parse_mode: 'HTML' }); } })() }}",
        "options": {}
