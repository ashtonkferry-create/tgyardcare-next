    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.telegram.org/bot{{ $env.{{ $env.TG_TELEGRAM_BOT_TOKEN }} || '{{ $env.TG_TELEGRAM_BOT_TOKEN }}' }}/sendMessage",
        "sendHeaders": true,
        "headerParameters": {
