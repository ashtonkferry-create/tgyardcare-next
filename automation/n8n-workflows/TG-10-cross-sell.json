{
  "name": "TG-10 Cross-Sell Engine",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 15 1 */2 *"
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 300]
    },
    {
      "parameters": {
        "url": "https://lwtmvzhwekgdxkaisfra.supabase.co/rest/v1/leads",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "status",
              "value": "in.(customer,active,converted)"
            },
            {
              "name": "select",
              "value": "id,first_name,last_name,email,phone,service"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "{{ $env.TG_SUPABASE_ANON_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.TG_SUPABASE_ANON_KEY }}"
            }
          ]
        },
        "options": {}
      },
      "id": "fetch-customers",
      "name": "Fetch Customers with Service History",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [260, 300],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const customers = $input.all().map(i => i.json);\n\nconst crossSellMap = {\n  'mowing': ['fertilization', 'aeration', 'spring cleanup', 'fall cleanup'],\n  'lawn mowing': ['fertilization', 'aeration', 'spring cleanup', 'fall cleanup'],\n  'lawn care': ['mulching', 'garden bed care', 'bush trimming', 'gutter cleaning'],\n  'fertilization': ['aeration', 'herbicide', 'overseeding'],\n  'aeration': ['fertilization', 'overseeding'],\n  'spring cleanup': ['mulching', 'garden bed care', 'fertilization'],\n  'fall cleanup': ['leaf removal', 'gutter cleaning', 'snow removal'],\n  'mulching': ['garden bed care', 'bush trimming', 'weeding'],\n  'snow removal': ['gutter guard installation', 'gutter cleaning'],\n  'gutter cleaning': ['gutter guard installation'],\n  'hardscaping': ['mulching', 'garden bed care', 'lawn care']\n};\n\nconst results = [];\nfor (const c of customers) {\n  if (!c.email) continue;\n  const currentService = (c.service || '').toLowerCase().trim();\n  const recommendations = crossSellMap[currentService] || ['fertilization', 'aeration'];\n  const topRecs = recommendations.slice(0, 2);\n\n  results.push({\n    json: {\n      lead_id: c.id,\n      first_name: c.first_name || 'Neighbor',\n      email: c.email,\n      current_service: c.service || 'yard care',\n      recommended_services: topRecs,\n      rec1: topRecs[0] || 'fertilization',\n      rec2: topRecs[1] || 'aeration'\n    }\n  });\n}\n\nif (results.length === 0) {\n  return [{ json: { _skip: true, _sent_count: 0 } }];\n}\n\nreturn results;"
      },
      "id": "analyze-crosssell",
      "name": "Analyze Cross-Sell Opportunities",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [520, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "filter-has-email",
              "leftValue": "={{ $json._skip }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "filter-skip",
      "name": "Filter Valid Customers",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [740, 300]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\nlet count = 0;\n\nconst formatService = (s) => (s || '').replace(/[-_]/g, ' ').replace(/\\b\\w/g, c => c.toUpperCase());\n\nfor (const item of items) {\n  const d = item.json;\n  const name = d.first_name || 'Neighbor';\n  const currentService = formatService(d.current_service);\n  const rec1 = formatService(d.rec1);\n  const rec2 = formatService(d.rec2);\n\n  const subject = `${name}, have you tried ${rec1}?`;\n\n  const html_body = `<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n</head>\n<body style=\"margin:0; padding:0; background-color:#f4f4f4; font-family:Arial, Helvetica, sans-serif;\">\n  <span style=\"display:none;font-size:0;color:#f4f4f4;\">Level up your yard care with services tailored just for you</span>\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#f4f4f4; padding:20px 0;\">\n    <tr>\n      <td align=\"center\">\n        <table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#ffffff; border-radius:8px; overflow:hidden;\">\n          <!-- Header -->\n          <tr>\n            <td style=\"background:linear-gradient(135deg, #166534, #15803d); padding:32px 40px; text-align:center;\">\n              <h1 style=\"margin:0; color:#ffffff; font-size:24px; font-weight:700;\">TotalGuard Yard Care</h1>\n              <p style=\"margin:8px 0 0; color:#bbf7d0; font-size:14px;\">Level Up Your Yard Care</p>\n            </td>\n          </tr>\n          <!-- Greeting -->\n          <tr>\n            <td style=\"padding:32px 40px 16px;\">\n              <p style=\"margin:0; font-size:18px; color:#333; font-weight:600;\">Hi ${name},</p>\n              <p style=\"margin:12px 0 0; font-size:15px; line-height:1.6; color:#555;\">You already trust us with <strong>${currentService}</strong> -- here's how to get even more from your property:</p>\n            </td>\n          </tr>\n          <!-- Recommendation 1 -->\n          <tr>\n            <td style=\"padding:0 40px 16px;\">\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#f0fdf4; border-radius:8px; border-left:4px solid #166534;\">\n                <tr>\n                  <td style=\"padding:20px 24px;\">\n                    <p style=\"margin:0 0 4px; font-size:13px; color:#166534; font-weight:700; text-transform:uppercase; letter-spacing:0.5px;\">Recommended for You</p>\n                    <p style=\"margin:0 0 8px; font-size:18px; font-weight:700; color:#166534;\">${rec1}</p>\n                    <p style=\"margin:0; font-size:14px; line-height:1.6; color:#555;\">A perfect complement to your ${currentService} service. Many of our customers bundle these together for the best results.</p>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n          <!-- Recommendation 2 -->\n          <tr>\n            <td style=\"padding:0 40px 24px;\">\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#fffbeb; border-radius:8px; border-left:4px solid #d4a017;\">\n                <tr>\n                  <td style=\"padding:20px 24px;\">\n                    <p style=\"margin:0 0 4px; font-size:13px; color:#92400e; font-weight:700; text-transform:uppercase; letter-spacing:0.5px;\">Also Consider</p>\n                    <p style=\"margin:0 0 8px; font-size:18px; font-weight:700; color:#92400e;\">${rec2}</p>\n                    <p style=\"margin:0; font-size:14px; line-height:1.6; color:#555;\">Take your yard to the next level. Ask us about adding this to your service plan.</p>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n          <!-- CTA -->\n          <tr>\n            <td style=\"padding:0 40px 24px;\" align=\"center\">\n              <a href=\"https://tgyardcare.com/contact?utm_source=email&utm_medium=cross-sell&utm_campaign=tg10\" target=\"_blank\" style=\"display:inline-block; background-color:#166534; color:#ffffff; font-size:16px; font-weight:700; text-decoration:none; padding:14px 40px; border-radius:8px;\">Add a Service</a>\n            </td>\n          </tr>\n          <!-- Social Proof -->\n          <tr>\n            <td style=\"padding:0 40px 32px;\">\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#fafafa; border-radius:8px;\">\n                <tr>\n                  <td style=\"padding:16px 24px; text-align:center;\">\n                    <p style=\"margin:0 0 4px; font-size:18px; color:#d4a017;\">&#9733;&#9733;&#9733;&#9733;&#9733;</p>\n                    <p style=\"margin:0; font-size:13px; color:#888;\">4.9 average rating &bull; 500+ properties served &bull; Licensed &amp; insured</p>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n          <!-- Footer -->\n          <tr>\n            <td style=\"background-color:#1a1a2e; padding:24px 40px; text-align:center;\">\n              <p style=\"margin:0 0 8px; font-size:14px; color:#a0a0b0;\">TotalGuard Yard Care</p>\n              <p style=\"margin:0 0 8px; font-size:14px; color:#a0a0b0;\">Madison, WI &bull; (608) 535-6057</p>\n              <p style=\"margin:0; font-size:12px; color:#666680;\">You received this because you are a valued TotalGuard customer.</p>\n            </td>\n          </tr>\n        </table>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>`;\n\n  results.push({\n    json: {\n      to_email: d.email,\n      subject,\n      html_body,\n      workflow_name: 'TG-10',\n      email_type: 'cross_sell'\n    }\n  });\n  count++;\n}\n\nif (results.length > 0) {\n  results[results.length - 1].json._sent_count = count;\n}\n\nreturn results;"
      },
      "id": "build-email",
      "name": "Build Cross-Sell Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 300]
    },
    {
      "parameters": {
        "workflowId": "FSRv5y8YzMjpyBtc"
      },
      "id": "send-email",
      "name": "Send via TG-95",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.1,
      "position": [1200, 300]
    },
    {
      "parameters": {
        "chatId": "{{ $env.TG_TELEGRAM_CHAT_ID }}",
        "text": "=**TG-10 Cross-Sell Campaign Complete**\n\nEmails sent: {{ $json._sent_count || 0 }}\nSchedule: Bi-monthly (1st of Jan/Mar/May/Jul/Sep/Nov)\nNext run: 1st of next odd month at 10am CT",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "telegram-summary",
      "name": "Telegram Summary",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1440, 300],
      "credentials": {
        "telegramApi": {
          "id": "V404qLIDXjmyzNeS",
          "name": "Telegram"
        }
      }
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [
        [
          {
            "node": "Fetch Customers with Service History",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Customers with Service History": {
      "main": [
        [
          {
            "node": "Analyze Cross-Sell Opportunities",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Analyze Cross-Sell Opportunities": {
      "main": [
        [
          {
            "node": "Filter Valid Customers",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Filter Valid Customers": {
      "main": [
        [
          {
            "node": "Build Cross-Sell Email",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Build Cross-Sell Email": {
      "main": [
        [
          {
            "node": "Send via TG-95",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send via TG-95": {
      "main": [
        [
          {
            "node": "Telegram Summary",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "active": false
}