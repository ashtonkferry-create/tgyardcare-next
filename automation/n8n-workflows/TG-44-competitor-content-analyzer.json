{
  "name": "TG-44-competitor-content-analyzer",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 12 * * 1"
            }
          ]
        }
      },
      "id": "trigger-competitor-content",
      "name": "Schedule - Monday 7am CT",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        0,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $vars.TG_SUPABASE_URL }}/rest/v1/competitor_social_posts",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $vars.TG_SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $vars.TG_SUPABASE_SERVICE_KEY }}"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "created_at",
              "value": "=gte.{{ new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString() }}"
            },
            {
              "name": "select",
              "value": "id,competitor_name,platform,caption,likes,comments,shares,content_type,posted_at"
            },
            {
              "name": "order",
              "value": "likes.desc"
            },
            {
              "name": "limit",
              "value": "20"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "get-competitor-posts",
      "name": "Get Competitor Social Posts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        220,
        300
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const posts = Array.isArray($input.first().json) ? $input.first().json : [];\nif (posts.length === 0) {\n  return [{ json: { noPosts: true, message: 'No competitor posts found in last 7 days' } }];\n}\nconst summary = posts.map(p => `[${p.competitor_name}] ${p.platform}: \"${(p.caption||'').substring(0,100)}\" — ${p.likes||0} likes, ${p.comments||0} comments`).join('\\n');\nreturn [{ json: { posts, summary, postCount: posts.length } }];"
      },
      "id": "prepare-analysis-prompt",
      "name": "Prepare Analysis Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-posts",
              "leftValue": "={{ !$json.noPosts }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "has-posts-check",
      "name": "Has Competitor Posts?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        660,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $vars.TG_ANTHROPIC_API_KEY }}"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 600,\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"Analyze these competitor lawn care social posts from the Madison WI market. What content gaps does TotalGuard Yard Care have? What topics and formats perform well? What should TotalGuard post more of? Give 3-5 actionable recommendations.\\n\\nCompetitor posts this week:\\n{{ $json.summary }}\\n\\nReturn as plain text bullet points.\"\n  }]\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "anthropic-analysis",
      "name": "Anthropic Competitor Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        880,
        200
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const analysisRaw = $input.first().json;\nconst promptData = $('Prepare Analysis Prompt').first().json;\nconst analysis = analysisRaw?.content?.[0]?.text || 'Analysis unavailable';\nreturn [{ json: { analysis, postCount: promptData.postCount, analyzedAt: new Date().toISOString() } }];"
      },
      "id": "parse-analysis",
      "name": "Parse Analysis Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1100,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.TG_SUPABASE_URL }}/rest/v1/competitor_social_posts",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $vars.TG_SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $vars.TG_SUPABASE_SERVICE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=minimal"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"competitor_name\": \"_weekly_analysis\",\n  \"platform\": \"all\",\n  \"ai_analysis\": {{ JSON.stringify($json.analysis) }},\n  \"posts_analyzed\": {{ $json.postCount }},\n  \"analyzed_at\": \"{{ $json.analyzedAt }}\",\n  \"created_at\": \"{{ $json.analyzedAt }}\"\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "insert-analysis-record",
      "name": "Insert Analysis Record",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1320,
        200
      ],
      "continueOnFail": true
    },
    {
      "id": "sms-owner-analysis",
      "name": "SMS Owner - Analysis Ready",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1540,
        200
      ],
      "continueOnFail": true,
      "parameters": {
        "method": "POST",
        "url": "https://api.brevo.com/v3/transactionalSMS/sms",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "api-key",
              "value": "={{$vars.TG_BREVO_API_KEY}}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {
              "name": "sender",
              "value": "TotalGuard"
            },
            {
              "name": "recipient",
              "value": "={{ $vars.TG_OWNER_PHONE }}"
            },
            {
              "name": "content"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { skipped: true, reason: 'no_competitor_posts_this_week' } }];"
      },
      "id": "no-competitor-posts",
      "name": "No Competitor Posts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        400
      ]
    }
  ],
  "connections": {
    "Schedule - Monday 7am CT": {
      "main": [
        [
          {
            "node": "Get Competitor Social Posts",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Competitor Social Posts": {
      "main": [
        [
          {
            "node": "Prepare Analysis Prompt",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Prepare Analysis Prompt": {
      "main": [
        [
          {
            "node": "Has Competitor Posts?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Has Competitor Posts?": {
      "main": [
        [
          {
            "node": "Anthropic Competitor Analysis",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "No Competitor Posts",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Anthropic Competitor Analysis": {
      "main": [
        [
          {
            "node": "Parse Analysis Result",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse Analysis Result": {
      "main": [
        [
          {
            "node": "Insert Analysis Record",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Insert Analysis Record": {
      "main": [
        [
          {
            "node": "SMS Owner - Analysis Ready",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "availableInMCP": true
  }
}