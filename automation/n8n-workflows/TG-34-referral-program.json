        300
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const webhook = $('Webhook Trigger').item.json.body;\nconst referrer = $('Find Referrer in Leads').item.json;\nconst referrerPhone = (Array.isArray(referrer) && referrer[0] && referrer[0].phone) ? referrer[0].phone : null;\nconst referrerName = webhook.referrer_name || 'there';\nconst newLeadName = webhook.new_lead_name || 'someone';\nconst service = webhook.service || 'yard care';\n\nif (!referrerPhone) {\n  return [{ json: { _skip: true, reason: 'no_referrer_phone_found' } }];\n}\n\nconst firstName = referrerName.split(' ')[0];\n\nconst messageBody = `Hi ${firstName}! Great news — ${newLeadName} just mentioned you when they reached out about ${service}! Thanks for spreading the word. Your discount will be applied to your next service. — TotalGuard`;\n\nreturn [{ json: {\n  to_phone: referrerPhone,\n  message_body: messageBody,\n  workflow_name: 'TG-34',\n  message_type: 'referral_thank_you',\n  referrer_name: referrerName,\n  new_lead_name: newLeadName,\n  service: service\n} }];"
      },
      "id": "tg34-build-sms",
      "name": "Build Thank Referrer SMS",
