        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ referral_code: ($json[0] && $json[0].referral_code) || null, referred_name: $('Webhook Trigger').item.json.body.new_lead_name, referred_email: null, status: 'pending', created_at: new Date().toISOString() }) }}",
        "options": {}
