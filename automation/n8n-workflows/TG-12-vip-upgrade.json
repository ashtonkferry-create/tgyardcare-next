{
  "name": "TG-12-vip-upgrade",
  "nodes": [
    {
      "parameters": { "rule": { "interval": [{ "field": "cronExpression", "expression": "0 14 1 * *" }] } },
      "id": "schedule",
      "name": "Monthly 1st 9am CT",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=={{$vars.TG_SUPABASE_URL}}/rest/v1/customers?select=id,first_name,email,job_count,total_spend,referrals_count,reviews_count,tier&order=total_spend.desc&limit=50",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "apikey", "value": "={{$vars.TG_SUPABASE_ANON_KEY}}" }, { "name": "Authorization", "value": "=Bearer {{$vars.TG_SUPABASE_SERVICE_KEY}}" }] }
      },
      "id": "fetch-customers",
      "name": "Fetch Top Customers",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 300]
    },
    {
      "parameters": {
        "jsCode": "const customers = $input.all().map(i => i.json);\nconst threshold = Math.floor(customers.length * 0.2);\nconst vipCandidates = customers.slice(0, threshold);\n// Only upgrade customers not already VIP\nconst newVips = vipCandidates.filter(c => c.tier !== 'vip');\nreturn newVips.length > 0 ? newVips.map(c => ({ json: c })) : [{ json: { _skip: true } }];"
      },
      "id": "select-vip",
      "name": "Select Top 20% VIPs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [{ "leftValue": "={{ $json._skip }}", "rightValue": true, "operator": { "type": "boolean", "operation": "notEquals" } }],
          "combinator": "and"
        }
      },
      "id": "filter-skip",
      "name": "Filter Skipped",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [600, 300]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=={{$vars.TG_SUPABASE_URL}}/rest/v1/customers?id=eq.{{$json.id}}",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "apikey", "value": "={{$vars.TG_SUPABASE_ANON_KEY}}" }, { "name": "Authorization", "value": "=Bearer {{$vars.TG_SUPABASE_SERVICE_KEY}}" }, { "name": "Content-Type", "value": "application/json" }] },
        "sendBody": true,
        "bodyParameters": { "parameters": [{ "name": "tier", "value": "vip" }] }
      },
      "id": "update-vip",
      "name": "Mark as VIP",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [780, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.brevo.com/v3/smtp/email",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "api-key", "value": "={{$vars.TG_BREVO_API_KEY}}" }, { "name": "Content-Type", "value": "application/json" }] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"sender\": { \"name\": \"TotalGuard Yard Care\", \"email\": \"totalguardllc@gmail.com\" }, \"to\": [{ \"email\": \"{{ $json.email }}\", \"name\": \"{{ $json.first_name }}\" }], \"subject\": \"You're a TotalGuard VIP!\", \"textContent\": \"Hi {{ $json.first_name }},\\n\\nAs one of our most valued customers, we're upgrading you to VIP status! Your benefits:\\n\\n✅ Priority scheduling\\n✅ 10% loyalty discount on all services\\n✅ Free seasonal consultation\\n✅ Early access to seasonal booking\\n\\nThank you for trusting TotalGuard with your yard!\\n\\n- The TotalGuard Team\" }"
      },
      "id": "send-vip-email",
      "name": "Send VIP Welcome Email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1000, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=={{$vars.TG_SUPABASE_URL}}/rest/v1/email_sends",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "apikey", "value": "={{$vars.TG_SUPABASE_ANON_KEY}}" }, { "name": "Authorization", "value": "=Bearer {{$vars.TG_SUPABASE_SERVICE_KEY}}" }, { "name": "Content-Type", "value": "application/json" }, { "name": "Prefer", "value": "return=minimal" }] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"contact_email\": \"{{ $json.email }}\", \"workflow_name\": \"vip_upgrade\", \"email_type\": \"vip_welcome\" }"
      },
      "id": "log-send",
      "name": "Log to email_sends",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1220, 300],
      "continueOnFail": true
    }
  ],
  "connections": {
    "Monthly 1st 9am CT": { "main": [[{ "node": "Fetch Top Customers", "type": "main", "index": 0 }]] },
    "Fetch Top Customers": { "main": [[{ "node": "Select Top 20% VIPs", "type": "main", "index": 0 }]] },
    "Select Top 20% VIPs": { "main": [[{ "node": "Filter Skipped", "type": "main", "index": 0 }]] },
    "Filter Skipped": { "main": [[{ "node": "Mark as VIP", "type": "main", "index": 0 }]] },
    "Mark as VIP": { "main": [[{ "node": "Send VIP Welcome Email", "type": "main", "index": 0 }]] },
    "Send VIP Welcome Email": { "main": [[{ "node": "Log to email_sends", "type": "main", "index": 0 }]] }
  },
  "settings": { "availableInMCP": true }
}
